<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>TAKE</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=JetBrains+Mono:wght@300;400;700&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --red: #ff2020;
    --red-dim: #991010;
    --white: #f0ede8;
    --black: #0a0a0a;
    --gray: #1a1a1a;
    --overlay: rgba(10,10,10,0.55);
    --glass: rgba(240,237,232,0.08);
    --glass-border: rgba(240,237,232,0.15);
  }

  html, body {
    width: 100%; height: 100%;
    background: var(--black);
    color: var(--white);
    font-family: 'JetBrains Mono', monospace;
    overflow: hidden;
    touch-action: manipulation;
  }

  /* ── CAMERA FEED ── */
  #camera-wrap {
    position: fixed; inset: 0;
    background: #000;
  }

  #video {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Полупрозрачный оверлей в режиме паузы */
  #pause-overlay {
    position: fixed; inset: 0;
    background: var(--overlay);
    backdrop-filter: blur(2px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    z-index: 5;
  }
  #pause-overlay.active { opacity: 1; }

  /* ── REC INDICATOR ── */
  #rec-badge {
    position: fixed;
    top: 20px; left: 20px;
    display: flex; align-items: center; gap: 8px;
    z-index: 20;
    opacity: 0;
    transition: opacity 0.2s;
  }
  #rec-badge.visible { opacity: 1; }

  .rec-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: var(--red);
    animation: blink 1s ease-in-out infinite;
  }

  @keyframes blink {
    0%,100% { opacity: 1; }
    50% { opacity: 0.2; }
  }

  #rec-label {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 3px;
    color: var(--red);
  }

  /* ── TAKE COUNTER ── */
  #take-counter {
    position: fixed;
    top: 16px;
    left: 50%; transform: translateX(-50%);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 15px;
    letter-spacing: 4px;
    color: rgba(240,237,232,0.5);
    z-index: 20;
    white-space: nowrap;
  }

  /* ── TIMER ── */
  #timer {
    position: fixed;
    top: 20px; right: 20px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    color: rgba(240,237,232,0.6);
    z-index: 20;
    font-variant-numeric: tabular-nums;
  }

  /* ── TAKES LIST (sidebar) ── */
  #takes-list {
    position: fixed;
    left: 0; top: 0; bottom: 0;
    width: 56px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    z-index: 20;
    padding: 80px 0;
  }

  .take-pip {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: rgba(240,237,232,0.25);
    transition: all 0.3s;
    cursor: default;
  }
  .take-pip.done {
    background: var(--white);
    width: 8px; height: 8px;
  }
  .take-pip.recording {
    background: var(--red);
    width: 10px; height: 10px;
    box-shadow: 0 0 8px var(--red);
  }

  /* ── BOTTOM BAR ── */
  #bottom-bar {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    padding: 24px 24px 40px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    z-index: 30;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%);
  }

  /* Кнопка удалить дубль */
  #btn-delete {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    cursor: pointer;
    opacity: 0.85;
    transition: opacity 0.2s, transform 0.15s;
    -webkit-tap-highlight-color: transparent;
    user-select: none;
    min-width: 64px;
  }
  #btn-delete:active { transform: scale(0.92); }
  #btn-delete.disabled { opacity: 0.2; pointer-events: none; }

  .btn-icon {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: var(--glass);
    border: 1px solid var(--glass-border);
    display: flex; align-items: center; justify-content: center;
    backdrop-filter: blur(8px);
  }

  #btn-delete .btn-icon {
    background: rgba(255,32,32,0.12);
    border-color: rgba(255,32,32,0.3);
  }

  .btn-label {
    font-size: 9px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(240,237,232,0.5);
    text-align: center;
    line-height: 1.3;
  }

  #delete-count-badge {
    position: absolute;
    top: -4px; right: -4px;
    width: 18px; height: 18px;
    border-radius: 50%;
    background: var(--red);
    font-size: 10px;
    font-weight: 700;
    display: none;
    align-items: center;
    justify-content: center;
    color: #fff;
  }
  #delete-count-badge.show { display: flex; }

  .icon-wrap { position: relative; }

  /* Главная кнопка записи */
  #btn-record {
    width: 72px; height: 72px;
    border-radius: 50%;
    cursor: pointer;
    position: relative;
    -webkit-tap-highlight-color: transparent;
    user-select: none;
    transition: transform 0.15s;
    flex-shrink: 0;
  }
  #btn-record:active { transform: scale(0.94); }

  .record-ring {
    position: absolute; inset: -4px;
    border-radius: 50%;
    border: 2px solid rgba(240,237,232,0.3);
    transition: border-color 0.3s;
  }
  #btn-record.recording .record-ring {
    border-color: var(--red);
    animation: ring-pulse 1.5s ease-in-out infinite;
  }

  @keyframes ring-pulse {
    0%,100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.06); opacity: 0.6; }
  }

  .record-inner {
    width: 100%; height: 100%;
    border-radius: 50%;
    background: var(--white);
    transition: all 0.25s cubic-bezier(0.4,0,0.2,1);
    display: flex; align-items: center; justify-content: center;
  }
  #btn-record.recording .record-inner {
    background: var(--red);
    border-radius: 16px;
    width: 38px; height: 38px;
    margin: 17px;
  }

  /* Кнопка монтаж */
  #btn-edit {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    cursor: pointer;
    opacity: 0.85;
    transition: opacity 0.2s, transform 0.15s;
    -webkit-tap-highlight-color: transparent;
    user-select: none;
    min-width: 64px;
  }
  #btn-edit:active { transform: scale(0.92); }
  #btn-edit.disabled { opacity: 0.2; pointer-events: none; }

  /* ── STATUS MESSAGE ── */
  #status-msg {
    position: fixed;
    bottom: 130px; left: 50%; transform: translateX(-50%);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(240,237,232,0.45);
    z-index: 25;
    white-space: nowrap;
    transition: opacity 0.4s;
  }

  /* ── MODAL ── */
  #modal-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(12px);
    z-index: 100;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  #modal-overlay.show { display: flex; }

  #modal {
    background: #111;
    border: 1px solid rgba(240,237,232,0.1);
    border-radius: 16px;
    padding: 32px 24px;
    width: 100%;
    max-width: 420px;
    text-align: center;
  }

  #modal h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    letter-spacing: 4px;
    margin-bottom: 8px;
  }

  #modal p {
    font-size: 12px;
    color: rgba(240,237,232,0.5);
    letter-spacing: 1px;
    margin-bottom: 28px;
    line-height: 1.6;
  }

  #modal-takes {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    margin-bottom: 28px;
  }

  .modal-take-chip {
    padding: 6px 14px;
    border-radius: 20px;
    background: var(--glass);
    border: 1px solid var(--glass-border);
    font-size: 11px;
    letter-spacing: 1px;
    color: rgba(240,237,232,0.7);
  }

  #modal-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .modal-btn {
    width: 100%;
    padding: 14px;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: transform 0.15s, opacity 0.2s;
  }
  .modal-btn:active { transform: scale(0.97); }

  .modal-btn-primary {
    background: var(--white);
    color: var(--black);
  }

  .modal-btn-secondary {
    background: transparent;
    border: 1px solid rgba(240,237,232,0.2);
    color: rgba(240,237,232,0.6);
  }

  /* ── PROGRESS BAR (рендер) ── */
  #render-progress {
    position: fixed; inset: 0;
    background: var(--black);
    z-index: 200;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 24px;
  }
  #render-progress.show { display: flex; }

  #render-progress h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 6px;
  }

  .progress-bar-wrap {
    width: 260px;
    height: 3px;
    background: rgba(240,237,232,0.1);
    border-radius: 2px;
    overflow: hidden;
  }

  #progress-fill {
    height: 100%;
    background: var(--white);
    border-radius: 2px;
    width: 0%;
    transition: width 0.3s;
  }

  #render-label {
    font-size: 11px;
    letter-spacing: 2px;
    color: rgba(240,237,232,0.4);
  }

  /* ── NO CAMERA ── */
  #no-camera {
    position: fixed; inset: 0;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    text-align: center;
    padding: 32px;
    z-index: 50;
  }
  #no-camera.show { display: flex; }
  #no-camera h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 4px;
  }
  #no-camera p {
    font-size: 12px;
    color: rgba(240,237,232,0.5);
    letter-spacing: 1px;
  }

  /* Double-tap hint */
  #delete-hint {
    position: fixed;
    bottom: 130px; right: 20px;
    font-size: 9px;
    letter-spacing: 1.5px;
    color: rgba(255,32,32,0.5);
    text-transform: uppercase;
    z-index: 25;
    text-align: right;
    line-height: 1.6;
    opacity: 0;
    transition: opacity 0.4s;
  }
  #delete-hint.show { opacity: 1; }

  svg { display: block; }
</style>
</head>
<body>

<!-- Camera -->
<div id="camera-wrap">
  <video id="video" autoplay muted playsinline></video>
</div>

<!-- Pause overlay -->
<div id="pause-overlay"></div>

<!-- REC badge -->
<div id="rec-badge">
  <div class="rec-dot"></div>
  <div id="rec-label">REC</div>
</div>

<!-- Take counter -->
<div id="take-counter">TAKE 1</div>

<!-- Timer -->
<div id="timer">00:00</div>

<!-- Takes sidebar -->
<div id="takes-list"></div>

<!-- Status -->
<div id="status-msg">НАЖМИТЕ ДЛЯ ЗАПИСИ</div>

<!-- Delete hint -->
<div id="delete-hint">2× УДАЛИТЬ 2 ДУБЛЯ</div>

<!-- Bottom bar -->
<div id="bottom-bar">
  <div id="btn-delete" class="disabled" onclick="handleDelete()">
    <div class="icon-wrap">
      <div class="btn-icon">
        <div id="delete-count-badge">1</div>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="3 6 5 6 21 6"></polyline>
          <path d="M19 6l-1 14H6L5 6"></path>
          <path d="M10 11v6M14 11v6"></path>
          <path d="M9 6V4h6v2"></path>
        </svg>
      </div>
    </div>
    <span class="btn-label">УДАЛИТЬ<br>ДУБЛЬ</span>
  </div>

  <div id="btn-record" onclick="handleRecord()">
    <div class="record-ring"></div>
    <div class="record-inner"></div>
  </div>

  <div id="btn-edit" class="disabled" onclick="openModal()">
    <div class="btn-icon">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="6" y1="3" x2="6" y2="15"></line>
        <circle cx="18" cy="6" r="3"></circle>
        <circle cx="6" cy="18" r="3"></circle>
        <path d="M18 9a9 9 0 0 1-9 9"></path>
      </svg>
    </div>
    <span class="btn-label">МОНТАЖ</span>
  </div>
</div>

<!-- Modal -->
<div id="modal-overlay">
  <div id="modal">
    <h2>МОНТАЖ</h2>
    <p id="modal-desc">Склеить все дубли в одно видео?</p>
    <div id="modal-takes"></div>
    <div id="modal-actions">
      <button class="modal-btn modal-btn-primary" onclick="startRender()">СКЛЕИТЬ И СКАЧАТЬ</button>
      <button class="modal-btn modal-btn-secondary" onclick="closeModal()">ПРОДОЛЖИТЬ СЪЁМКУ</button>
    </div>
  </div>
</div>

<!-- Render progress -->
<div id="render-progress">
  <h2>МОНТАЖ...</h2>
  <div class="progress-bar-wrap">
    <div id="progress-fill"></div>
  </div>
  <div id="render-label">ПОДГОТОВКА</div>
</div>

<!-- No camera -->
<div id="no-camera">
  <h2>НЕТ КАМЕРЫ</h2>
  <p>Разрешите доступ к камере<br>и микрофону в браузере</p>
</div>

<script>
// ── STATE ──
let stream = null;
let mediaRecorder = null;
let takes = []; // [{blob, duration}]
let currentChunks = [];
let isRecording = false;
let timerInterval = null;
let timerStart = 0;
let deleteClickTimeout = null;
let deleteClickCount = 0;

// ── INIT ──
async function init() {
  try {
    stream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: 'environment', width: { ideal: 1920 }, height: { ideal: 1080 } },
      audio: true
    });
    const video = document.getElementById('video');
    video.srcObject = stream;
    updateUI();
  } catch (e) {
    // Try front camera
    try {
      stream = await navigator.mediaDevices.getUserMedia({ video: true, audio: true });
      document.getElementById('video').srcObject = stream;
      updateUI();
    } catch (e2) {
      document.getElementById('no-camera').classList.add('show');
    }
  }
}

// ── RECORD ──
function handleRecord() {
  if (!stream) return;
  if (isRecording) stopRecording();
  else startRecording();
}

function startRecording() {
  if (!stream) return;
  currentChunks = [];

  const mimeType = getSupportedMimeType();
  try {
    mediaRecorder = new MediaRecorder(stream, mimeType ? { mimeType } : {});
  } catch(e) {
    mediaRecorder = new MediaRecorder(stream);
  }

  mediaRecorder.ondataavailable = e => {
    if (e.data && e.data.size > 0) currentChunks.push(e.data);
  };

  mediaRecorder.onstop = () => {
    const mimeType = mediaRecorder.mimeType || 'video/webm';
    const blob = new Blob(currentChunks, { type: mimeType });
    const duration = Date.now() - timerStart;
    takes.push({ blob, duration, mimeType });
    currentChunks = [];
    updateUI();
  };

  mediaRecorder.start(100);
  isRecording = true;
  timerStart = Date.now();
  startTimer();
  updateUI();

  // Resume video if paused
  document.getElementById('video').play();
}

function stopRecording() {
  if (mediaRecorder && mediaRecorder.state !== 'inactive') {
    mediaRecorder.stop();
  }
  isRecording = false;
  stopTimer();
  updateUI();
}

function getSupportedMimeType() {
  const types = [
    'video/mp4;codecs=h264,aac',
    'video/mp4',
    'video/webm;codecs=vp9,opus',
    'video/webm;codecs=vp8,opus',
    'video/webm',
  ];
  for (const type of types) {
    if (MediaRecorder.isTypeSupported(type)) return type;
  }
  return '';
}

// ── TIMER ──
function startTimer() {
  clearInterval(timerInterval);
  timerInterval = setInterval(updateTimer, 500);
  updateTimer();
}
function stopTimer() {
  clearInterval(timerInterval);
  document.getElementById('timer').textContent = '00:00';
}
function updateTimer() {
  const elapsed = Math.floor((Date.now() - timerStart) / 1000);
  const m = String(Math.floor(elapsed / 60)).padStart(2, '0');
  const s = String(elapsed % 60).padStart(2, '0');
  document.getElementById('timer').textContent = `${m}:${s}`;
}

// ── DELETE ──
function handleDelete() {
  if (isRecording || takes.length === 0) return;

  deleteClickCount++;
  clearTimeout(deleteClickTimeout);

  if (deleteClickCount === 1) {
    // Show hint: tap again to delete 2
    if (takes.length >= 2) {
      document.getElementById('delete-hint').classList.add('show');
    }
    deleteClickTimeout = setTimeout(() => {
      // Single tap: delete 1
      if (deleteClickCount === 1) {
        takes.pop();
        updateUI();
      }
      deleteClickCount = 0;
      document.getElementById('delete-hint').classList.remove('show');
    }, 400);
  } else if (deleteClickCount === 2) {
    // Double tap: delete 2
    clearTimeout(deleteClickTimeout);
    deleteClickCount = 0;
    document.getElementById('delete-hint').classList.remove('show');
    takes.splice(-2);
    updateUI();
    showStatus('УДАЛЕНО 2 ДУБЛЯ');
  }
}

// ── MODAL ──
function openModal() {
  if (isRecording) stopRecording();
  const desc = document.getElementById('modal-desc');
  const takesEl = document.getElementById('modal-takes');
  desc.textContent = `Склеить ${takes.length} ${pluralTake(takes.length)} в одно видео?`;

  takesEl.innerHTML = takes.map((t, i) => {
    const secs = Math.floor(t.duration / 1000);
    return `<div class="modal-take-chip">ДУБЛЬ ${i+1} · ${secs}с</div>`;
  }).join('');

  document.getElementById('modal-overlay').classList.add('show');
}

function closeModal() {
  document.getElementById('modal-overlay').classList.remove('show');
}

function pluralTake(n) {
  if (n === 1) return 'дубль';
  if (n >= 2 && n <= 4) return 'дубля';
  return 'дублей';
}

// ── RENDER (склейка) ──
async function startRender() {
  closeModal();
  if (takes.length === 0) return;

  const progress = document.getElementById('render-progress');
  const fill = document.getElementById('progress-fill');
  const label = document.getElementById('render-label');
  progress.classList.add('show');

  try {
    label.textContent = 'ЗАГРУЗКА ДУБЛЕЙ...';
    fill.style.width = '10%';

    // Load all blobs as ArrayBuffers
    const buffers = [];
    for (let i = 0; i < takes.length; i++) {
      const buf = await takes[i].blob.arrayBuffer();
      buffers.push(buf);
      fill.style.width = `${10 + (i+1) / takes.length * 30}%`;
    }

    label.textContent = 'СКЛЕЙКА...';
    fill.style.width = '50%';

    // Concatenate blobs (simple concat works for webm)
    const combined = new Blob(takes.map(t => t.blob), { type: takes[0].mimeType });

    fill.style.width = '90%';
    label.textContent = 'ПОДГОТОВКА ФАЙЛА...';

    await new Promise(r => setTimeout(r, 300));

    fill.style.width = '100%';
    label.textContent = 'ГОТОВО!';

    await new Promise(r => setTimeout(r, 400));

    // Download
    const url = URL.createObjectURL(combined);
    const ext = takes[0].mimeType.includes('mp4') ? 'mp4' : 'webm';
    const a = document.createElement('a');
    a.href = url;
    a.download = `take_${Date.now()}.${ext}`;
    a.click();
    setTimeout(() => URL.revokeObjectURL(url), 5000);

    progress.classList.remove('show');

    // Reset
    takes = [];
    updateUI();
    showStatus('СКАЧАНО!');

  } catch (e) {
    console.error(e);
    label.textContent = 'ОШИБКА. ПОПРОБУЙТЕ ЕЩЁ РАЗ.';
    setTimeout(() => progress.classList.remove('show'), 2000);
  }
}

// ── STATUS ──
let statusTimeout;
function showStatus(msg) {
  const el = document.getElementById('status-msg');
  el.textContent = msg;
  clearTimeout(statusTimeout);
  statusTimeout = setTimeout(() => {
    updateStatusText();
  }, 2000);
}

function updateStatusText() {
  const el = document.getElementById('status-msg');
  if (isRecording) {
    el.textContent = 'НАЖМИТЕ ДЛЯ СТОПА';
  } else if (takes.length === 0) {
    el.textContent = 'НАЖМИТЕ ДЛЯ ЗАПИСИ';
  } else {
    el.textContent = `ДУБЛЬ ${takes.length} ГОТОВ`;
  }
}

// ── UPDATE UI ──
function updateUI() {
  const btnRecord = document.getElementById('btn-record');
  const btnDelete = document.getElementById('btn-delete');
  const btnEdit = document.getElementById('btn-edit');
  const recBadge = document.getElementById('rec-badge');
  const pauseOverlay = document.getElementById('pause-overlay');
  const takeCounter = document.getElementById('take-counter');
  const deleteBadge = document.getElementById('delete-count-badge');

  // Recording state
  if (isRecording) {
    btnRecord.classList.add('recording');
    recBadge.classList.add('visible');
    pauseOverlay.classList.remove('active');
  } else {
    btnRecord.classList.remove('recording');
    recBadge.classList.remove('visible');
    // Show pause overlay if we have takes
    if (takes.length > 0) {
      pauseOverlay.classList.add('active');
    } else {
      pauseOverlay.classList.remove('active');
    }
  }

  // Take counter
  const currentTake = takes.length + (isRecording ? 0 : 1);
  if (isRecording) {
    takeCounter.textContent = `ДУБЛЬ ${takes.length + 1}`;
  } else if (takes.length === 0) {
    takeCounter.textContent = 'ДУБЛЬ 1';
  } else {
    takeCounter.textContent = `ДУБЛЬ ${takes.length + 1}`;
  }

  // Delete button
  if (takes.length > 0 && !isRecording) {
    btnDelete.classList.remove('disabled');
    if (takes.length >= 2) {
      deleteBadge.textContent = takes.length >= 2 ? '2' : '1';
      deleteBadge.classList.add('show');
    } else {
      deleteBadge.classList.remove('show');
    }
  } else {
    btnDelete.classList.add('disabled');
    deleteBadge.classList.remove('show');
  }

  // Edit button
  if (takes.length >= 1 && !isRecording) {
    btnEdit.classList.remove('disabled');
  } else {
    btnEdit.classList.add('disabled');
  }

  // Takes sidebar
  updateTakesList();

  // Status text
  updateStatusText();
}

function updateTakesList() {
  const list = document.getElementById('takes-list');
  const total = takes.length + (isRecording ? 1 : 0) + (isRecording ? 0 : 1);
  const maxPips = Math.min(total + 2, 12);

  list.innerHTML = '';
  for (let i = 0; i < maxPips; i++) {
    const pip = document.createElement('div');
    pip.className = 'take-pip';
    if (i < takes.length) {
      pip.classList.add('done');
    } else if (i === takes.length && isRecording) {
      pip.classList.add('recording');
    }
    list.appendChild(pip);
  }
}

// ── KEYBOARD / BLUETOOTH ──
// Bluetooth remote usually sends ArrowUp, ArrowDown, Enter, Space, VolumeUp, VolumeDown
// or media keys. We listen to keydown for universal support.
const TRIGGER_KEYS = new Set([
  ' ', 'Enter', 'ArrowUp', 'ArrowDown',
  'MediaPlayPause', 'MediaPlay', 'MediaPause',
  'VolumeUp', 'VolumeDown',
  'F5', 'F8', // some remotes
  'PageUp', 'PageDown',
]);

document.addEventListener('keydown', e => {
  if (TRIGGER_KEYS.has(e.key)) {
    e.preventDefault();
    handleRecord();
  }
});

// Also listen for gamepad events (some BT remotes appear as gamepad)
window.addEventListener('gamepadconnected', e => {
  console.log('Bluetooth gamepad connected:', e.gamepad.id);
  checkGamepad();
});

let gamepadPolling = false;
function checkGamepad() {
  if (gamepadPolling) return;
  gamepadPolling = true;
  let prevButtons = {};

  function poll() {
    const gamepads = navigator.getGamepads();
    for (const gp of gamepads) {
      if (!gp) continue;
      for (let i = 0; i < gp.buttons.length; i++) {
        const pressed = gp.buttons[i].pressed;
        if (pressed && !prevButtons[gp.index + '_' + i]) {
          handleRecord();
        }
        prevButtons[gp.index + '_' + i] = pressed;
      }
    }
    requestAnimationFrame(poll);
  }
  poll();
}

// ── START ──
init();
</script>
</body>
</html>
